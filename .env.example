# Copy this file to .env before first run:
#   cp .env.example .env

# Compose project name (container and volume prefix)
COMPOSE_PROJECT_NAME=course

# -------------------------
# Shared Postgres
# -------------------------
POSTGRES_IMAGE=postgres:16
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_ADMIN_DB=postgres
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres

# -------------------------
# Superset configuration
# -------------------------
SUPERSET_IMAGE=apachesuperset.docker.scarf.sh/apache/superset:6.0.0
SUPERSET_PORT=8088

# Generate a unique key for your local .env (make init does this automatically)
SUPERSET_SECRET_KEY=__CHANGE_ME__

# Superset docker-init.sh uses ADMIN_PASSWORD and creates username "admin"
ADMIN_PASSWORD=admin

# Superset metadata database connection
SUPERSET_DB_DIALECT=postgresql
SUPERSET_DB_NAME=superset_meta
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset

# Redis for Superset cache/results
REDIS_HOST=superset-redis
REDIS_PORT=6379

# Local development defaults
SUPERSET_ENV=development
SUPERSET_LOAD_EXAMPLES=no
FLASK_DEBUG=true
SUPERSET_LOG_LEVEL=info
PYTHONUNBUFFERED=1
MAPBOX_API_KEY=

# -------------------------
# Airflow configuration
# -------------------------
# Base image used by airflow/image/Dockerfile
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.7
# Final local image tag built by docker compose
AIRFLOW_CUSTOM_IMAGE_NAME=course-airflow:3.1.7-dbt
AIRFLOW_PORT=8080

# On Linux, use your user id to avoid root-owned files. make init sets this automatically.
AIRFLOW_UID=50000

# Airflow web UI admin account
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_ADMIN_EMAIL=admin@airflow.local

# Airflow metadata database connection
AIRFLOW_DB_NAME=airflow_meta
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# -------------------------
# Warehouse database (ETL/dbt target)
# -------------------------
WAREHOUSE_DB_HOST=postgres
WAREHOUSE_DB_PORT=5432
WAREHOUSE_DB_NAME=warehouse
WAREHOUSE_DB_USER=warehouse
WAREHOUSE_DB_PASSWORD=warehouse

# -------------------------
# Airviro ETL configuration
# -------------------------
AIRVIRO_BASE_URL=https://www.ohuseire.ee/api
AIRVIRO_API_LOCALE=en
# Lecture 4 defaults:
# - Tartu air quality station 8
# - Tartu pollen station 25
# Both lecture sources are discoverable from the live station metadata endpoint:
#   https://www.ohuseire.ee/api/station/en
# Lecture 5 can extend this list (for example add station 19) when the
# dimensional model grows to include explicit station handling.
AIRVIRO_AIR_STATION_IDS=8
AIRVIRO_POLLEN_STATION_IDS=25
AIRVIRO_RAW_SCHEMA=l4_raw
AIRVIRO_MART_SCHEMA=l4_mart
AIRVIRO_TIMEOUT_SECONDS=45
AIRVIRO_REQUEST_RETRIES=3
AIRVIRO_MIN_SPLIT_DAYS=7
AIRVIRO_AIR_WINDOW_DAYS=300
AIRVIRO_POLLEN_WINDOW_DAYS=365

# -------------------------
# Airflow DAG runtime knobs
# -------------------------
# Incremental DAG default window when no watermark exists.
AIRFLOW_AIRVIRO_INCREMENTAL_BOOTSTRAP_START=2020-01-01
# Max inclusive days processed in one incremental DAG run.
AIRFLOW_AIRVIRO_INCREMENTAL_MAX_DAYS=31
# Verbose ETL logs for incremental DAG task output.
AIRFLOW_AIRVIRO_INCREMENTAL_VERBOSE=false
# Verbose ETL logs for manual backfill DAG task output.
AIRFLOW_AIRVIRO_BACKFILL_VERBOSE=false

# Optional: set a generated Fernet key (kept empty for teaching simplicity)
AIRFLOW_FERNET_KEY=
AIRFLOW_DAGS_PAUSED_AT_CREATION=true
AIRFLOW_LOAD_EXAMPLES=false
